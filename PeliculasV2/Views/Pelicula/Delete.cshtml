@model MVC.ViewModels.PeliculaIndexViewModel

@{
    ViewData["Title"] = "Eliminar Pelicula";
}

<h2>Eliminar Pelicula</h2>
<h3 class="text-danger">¿Está seguro que desea eliminar esta Pelicula?</h3>
<hr />

<div>
    <h4>Pelicula</h4>
    <dl class="row">
        
        <dt class="col-sm-4">
            Titulo
        </dt>
        <dd class="col-sm-8">
            @Model.Titulo
        </dd>

        <dt class="col-sm-4">
            Anio
        </dt>
        <dd class="col-sm-8">
            @Model.Anio
        </dd>

        <dt class="col-sm-4">
            Categoria
        </dt>
        <dd class="col-sm-8">
            @Model.Categoria
        </dd>
        
    </dl>

    <form asp-action="Delete">
        
        <input type="hidden" asp-for="Id" />
        
        <input type="submit" value="Confirmar Eliminación" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Cancelar y Volver a la lista</a>
    </form>
</div>